rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }
    
    function isValidEmail(email) {
      return email is string && email.size() >= 3 && email.size() <= 254 && email.contains("@");
    }

    // Connection Test
    match /test/connection {
      allow read: if true;
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================

    // User Profiles
    match /users/{userId} {
      function isValidUser(data) {
        return (!('uid' in data) || data.uid == userId) &&
               (!('email' in data) || (data.email is string && (data.email == "" || isValidEmail(data.email)))) &&
               (!('displayName' in data) || data.displayName == null || data.displayName is string) &&
               (!('settings' in data) || data.settings == null || data.settings is map) &&
               (!('role' in data) || data.role == null || data.role is string) &&
               (!('completedTaskIds' in data) || data.completedTaskIds == null || data.completedTaskIds is list) &&
               (!('completedExamIds' in data) || data.completedExamIds == null || data.completedExamIds is list) &&
               (!('gardenActivePlant' in data) || data.gardenActivePlant == null || data.gardenActivePlant is map) &&
               (!('gardenDroplets' in data) || data.gardenDroplets == null || data.gardenDroplets is number) &&
               (!('gardenHarvested' in data) || data.gardenHarvested == null || data.gardenHarvested is list);
      }
      
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data);
      
      // Subcollections
      match /grades/{gradeId} {
        function isValidGrade(data) {
          return data.id == gradeId && data.uid == userId &&
                 data.name is string && data.name.size() > 0 &&
                 data.credits is number && data.grade is number;
        }
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidGrade(request.resource.data);
        allow update: if isOwner(userId) && isValidGrade(request.resource.data);
         allow delete: if isOwner(userId);
      }

      match /flashcardSets/{setId} {
        function isValidSet(data) {
          return data.id == setId && data.uid == userId &&
                 data.title is string && data.title.size() > 0 && data.title.size() < 100 &&
                 data.course is string && data.course.size() > 0 &&
                 data.cards is list && data.cards.size() > 0 && data.cards.size() < 100;
        }
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidSet(request.resource.data);
        allow update: if isOwner(userId) && isValidSet(request.resource.data);
        allow delete: if isOwner(userId);
      }

      match /chatSessions/{sessionId} {
        allow read, write: if isOwner(userId);
      }
    }

    // Global Collections
    match /schedule/{sessionId} {
      function isValidSession(data) {
        return data.id == sessionId &&
               data.name is string && data.name.size() > 0 &&
               data.day is int && data.day >= 0 && data.day <= 6 &&
               data.startTime is string && data.endTime is string;
      }
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated() && isValidSession(request.resource.data);
      allow delete: if isAuthenticated();
    }

    match /tasks/{taskId} {
      function isValidTask(data) {
        return data.id == taskId &&
               data.title is string && data.title.size() > 0 && data.title.size() < 100 &&
               data.course is string && data.course.size() > 0 &&
               data.dueDate is string &&
               data.type == 'task' &&
               data.priority in ['low', 'medium', 'high'] &&
               data.completed is bool;
      }
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated() && isValidTask(request.resource.data);
      allow delete: if isAuthenticated();
    }

    match /exams/{examId} {
      function isValidExam(data) {
        return data.id == examId &&
               data.title is string && data.title.size() > 0 && data.title.size() < 100 &&
               data.course is string && data.course.size() > 0 &&
               data.dueDate is string &&
               data.type == 'exam' &&
               data.priority in ['low', 'medium', 'high'] &&
               data.completed is bool;
      }
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated() && isValidExam(request.resource.data);
      allow delete: if isAuthenticated();
    }

    match /auditLogs/{logId} {
      function isValidLog(data) {
        return data.id == logId &&
               data.action in ['add', 'edit', 'delete', 'toggle'] &&
               data.targetName is string && data.targetName.size() > 0 && data.targetName.size() <= 200 &&
               data.targetType in ['jadwal', 'tugas', 'ujian'] &&
               data.adminName is string && data.adminName.size() > 0 && data.adminName.size() <= 100 &&
               data.timestamp is string;
      }
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated() && isValidLog(request.resource.data);
      allow delete: if isAuthenticated();
    }
  }
}
