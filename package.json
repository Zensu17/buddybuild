{
  "name": "buddybuild",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "dev": "concurrently -n frontend,backend -c blue,green \"npm run dev:frontend\" \"npm run dev:backend\"",
    "dev:frontend": "npm run dev --prefix frontend",
    "dev:backend": "python backend/main.py --reload",
    "build": "npm run build --prefix frontend",
    "start": "python backend/main.py",
    "lint": "npm run lint --prefix frontend",
    "clean": "npm run clean --prefix frontend",
    "backend:install": "pip install -r backend/requirements.txt",
    "install:all": "npm install && npm install --prefix frontend && npm run backend:install"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  },
  "dependencies": {
    "all": "^0.0.0"
  }
}
