{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User's academic profile and settings",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "major": { "type": "string" },
        "gpa": { "type": "number" },
        "role": { "type": "string" },
        "completedTaskIds": { "type": "array", "items": { "type": "string" } },
        "completedExamIds": { "type": "array", "items": { "type": "string" } },
        "settings": {
          "type": "object",
          "properties": {
            "notificationsEnabled": { "type": "boolean" },
            "pomodoroAutoStart": { "type": "boolean" },
            "theme": { "type": "string", "enum": ["light", "dark"] }
          }
        }
      },
      "required": ["uid", "email"]
    },
    "Task": {
      "title": "Task",
      "description": "Assignment or task for a course",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "uid": { "type": "string" },
        "type": { "type": "string", "enum": ["task"] },
        "title": { "type": "string" },
        "course": { "type": "string" },
        "dueDate": { "type": "string", "format": "date-time" },
        "reminderTime": { "type": "integer" },
        "priority": { "type": "string", "enum": ["low", "medium", "high"] },
        "completed": { "type": "boolean" },
        "notified": { "type": "boolean" }
      },
      "required": ["id", "uid", "title", "course", "dueDate"]
    },
    "Exam": {
      "title": "Exam",
      "description": "Exam or quiz for a course",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "uid": { "type": "string" },
        "type": { "type": "string", "enum": ["exam"] },
        "title": { "type": "string" },
        "course": { "type": "string" },
        "dueDate": { "type": "string", "format": "date-time" },
        "reminderTime": { "type": "integer" },
        "priority": { "type": "string", "enum": ["low", "medium", "high"] },
        "completed": { "type": "boolean" },
        "notified": { "type": "boolean" },
        "location": { "type": "string" }
      },
      "required": ["id", "uid", "title", "course", "dueDate"]
    },
    "ClassSession": {
      "title": "Class Session",
      "description": "A recurring class in the weekly schedule",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "room": { "type": "string" },
        "day": { "type": "integer" },
        "startTime": { "type": "string" },
        "endTime": { "type": "string" },
        "color": { "type": "string" }
      },
      "required": ["id", "uid", "name", "day", "startTime", "endTime"]
    },
    "CourseGrade": {
      "title": "Course Grade",
      "description": "Grade for a specific course",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "credits": { "type": "number" },
        "grade": { "type": "number" }
      },
      "required": ["id", "uid", "name", "credits", "grade"]
    },
    "FlashcardSet": {
      "title": "Flashcard Set",
      "description": "A set of flashcards for studying",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "uid": { "type": "string" },
        "title": { "type": "string" },
        "course": { "type": "string" },
        "cards": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "front": { "type": "string" },
              "back": { "type": "string" }
            }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "uid", "title", "course", "cards"]
    },
    "ChatSession": {
      "title": "Chat Session",
      "description": "An AI Study Buddy conversation session with messages",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "uid": { "type": "string" },
        "title": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "lastActive": { "type": "string", "format": "date-time" },
        "tokensUsed": { "type": "integer" },
        "messages": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "sender": { "type": "string", "enum": ["user", "assistant"] },
              "text": { "type": "string" },
              "timestamp": { "type": "string", "format": "date-time" },
              "promptTokens": { "type": "integer" },
              "candidatesTokens": { "type": "integer" },
              "totalTokens": { "type": "integer" }
            }
          }
        }
      },
      "required": ["id", "uid", "title", "createdAt", "messages"]
    },
    "AuditLog": {
      "title": "Audit Log",
      "description": "Admin auditing entries for academic data modifications",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "action": { "type": "string", "enum": ["add", "edit", "delete", "toggle"] },
        "targetName": { "type": "string" },
        "targetType": { "type": "string", "enum": ["jadwal", "tugas", "ujian"] },
        "adminName": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "action", "targetName", "targetType", "adminName", "timestamp"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/tasks/{taskId}": {
      "schema": "Task",
      "description": "Global tasks"
    },
    "/exams/{examId}": {
      "schema": "Exam",
      "description": "Global exams"
    },
    "/schedule/{sessionId}": {
      "schema": "ClassSession",
      "description": "Global class schedule"
    },
    "/users/{uid}/grades/{gradeId}": {
      "schema": "CourseGrade",
      "description": "User course grades"
    },
    "/users/{uid}/flashcardSets/{setId}": {
      "schema": "FlashcardSet",
      "description": "User flashcard sets"
    },
    "/users/{uid}/chatSessions/{sessionId}": {
      "schema": "ChatSession",
      "description": "User Study Buddy chat sessions"
    },
    "/auditLogs/{logId}": {
      "schema": "AuditLog",
      "description": "Global admin actions logs"
    }
  }
}
